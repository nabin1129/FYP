# Example environment variables for local development
# Copy this to a local `.env` and fill in secrets as needed (never commit real secrets).

# Flask config selection: development | testing | production
NETRACARE_CONFIG=development

# Security
SECRET_KEY=change-me-to-a-long-random-string-with-32+chars

# Admin user (development only)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# AI provider key
GEMINI_API_KEY=

# SMTP (required for forgot-password verification code emails)
SMTP_EMAIL=
SMTP_PASSWORD=

# CORS
CORS_ALLOWED_ORIGINS=*
